server:
  bind_addr: "[::1]:50051"

  # This folder must exist in the project root and contain all ML model folders.
  ml_backends_path: "ml-backends"

models:
  - name: "model3"
    device: "cpu"
    queue_capacity: 16

  # Add one entry per model folder under server.ml_backends_path.
  # device can be "cpu", "cuda" (GPU 0), or "cuda:<index>" for a specific GPU
  # on multi-GPU systems (e.g. "cuda:1").
  # queue_capacity must be greater than 0.
  # For models backed by main.py (instead of a .pt file), device and queue_capacity
  # are still required by this schema but are unused by the server.